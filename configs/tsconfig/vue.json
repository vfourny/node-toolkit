{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": "${configDir}",

    /* Emit */
    "declaration": true,

    /* Interop Constraints */
    "isolatedModules": true,

    /* Language and Environment */
    "jsx": "preserve",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "outDir": "${configDir}/dist",
    "paths": {
      "@/*": ["${configDir}/src/*"]
    },
    /* Modules */
    "rootDir": "${configDir}/src",
    /* Build Configuration */
    "tsBuildInfoFile": "${configDir}/.cache/vue.tsbuildinfo"
  },
  "exclude": [
    "${configDir}/node_modules",
    "${configDir}/dist",
    "${configDir}/coverage",
    "${configDir}/build"
  ],
  "extends": "./base.json",
  "include": ["${configDir}/src/**/*", "${configDir}/src/**/*.vue"]
}
