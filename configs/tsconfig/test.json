{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    /* Build Configuration */
    "tsBuildInfoFile": "${configDir}/.cache/test.tsbuildinfo",

    /* Types */
    "types": ["vitest/globals", "node"],

    /* Modules */
    "baseUrl": "${configDir}",
    "paths": {
      "@/*": ["${configDir}/src/*"],
      "@test/*": ["${configDir}/tests/*"]
    },

    /* Emit */
    "noEmit": true
  },
  "include": ["${configDir}/tests/**/*"],
  "exclude": ["${configDir}/node_modules", "${configDir}/dist"]
}
