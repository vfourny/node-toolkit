{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {

    /* Modules */
    "baseUrl": "${configDir}",

    /* Emit */
    "noEmit": true,
    "paths": {
      "@/*": ["${configDir}/src/*"],
      "@tests/*": ["${configDir}/tests/*"]
    },
    /* Build Configuration */
    "tsBuildInfoFile": "${configDir}/.cache/test.tsbuildinfo",

    /* Types */
    "types": ["vitest/globals", "node"]
  },
  "exclude": ["${configDir}/node_modules", "${configDir}/dist"],
  "extends": "./base.json",
  "include": ["${configDir}/tests/**/*"]
}
