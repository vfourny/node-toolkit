{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": "${configDir}",

    /* Emit */
    "declaration": true,
    "outDir": "${configDir}/dist",

    "paths": {
      "@/*": ["${configDir}/src/*"]
    },
    /* Modules */
    "rootDir": "${configDir}/src",
    /* Build Configuration */
    "tsBuildInfoFile": "${configDir}/.cache/node.tsbuildinfo",

    /* Types */
    "types": ["node"]
  },
  "exclude": [
    "${configDir}/node_modules",
    "${configDir}/dist",
    "${configDir}/.nuxt",
    "${configDir}/.output"
  ],
  "extends": "./base.json",
  "include": ["${configDir}/src/**/*"]
}
